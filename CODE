#!/usr/bin/env python3
"""
TEMPORAL MANIFOLDS: CONTINUOUS WEIGHT TRAJECTORIES
========================================================================
The real innovation: W(t) = W0 + Σ α_i(t) U_i V_iᵀ

This creates a continuous path through weight space that the network
MUST follow to solve the task - time becomes a necessary dimension.
"""

import torch
import torch.nn as nn
import torch.nn.functional as F
import torch.optim as optim
from torch.utils.data import DataLoader
from torchvision import datasets, transforms
import numpy as np
import matplotlib.pyplot as plt
from collections import defaultdict
import os

device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')
print(f"Using device: {device}")

# ----------------------------------------------------------------------
# Continuous Temporal Manifold Layer
# ----------------------------------------------------------------------
class ContinuousTemporalLayer(nn.Module):
    """
    W(t) = W0 + Σ α_i(t) U_i V_iᵀ
    
    Where α_i(t) are learnable basis functions of time.
    This creates a true continuous trajectory through weight space.
    """
    def __init__(self, in_features, out_features, rank=8, num_basis=5):
        super().__init__()
        
        self.in_features = in_features
        self.out_features = out_features
        self.rank = rank
        self.num_basis = num_basis
        
        # Base weight (starting point of trajectory)
        self.W0 = nn.Parameter(torch.randn(out_features, in_features) * 0.02)
        self.b0 = nn.Parameter(torch.zeros(out_features))
        
        # Trajectory components: U_i (out_features x rank) and V_i (in_features x rank)
        # These define the directions of movement through weight space
        self.U = nn.ParameterList([
            nn.Parameter(torch.randn(out_features, rank) * 0.1)  # Larger init
            for _ in range(num_basis)
        ])
        self.V = nn.ParameterList([
            nn.Parameter(torch.randn(in_features, rank) * 0.1)
            for _ in range(num_basis)
        ])
        
        # Basis functions α_i(t) - these map time to coefficients
        # Using Fourier features for smooth periodic/aperiodic trajectories
        self.freqs = nn.Parameter(torch.linspace(0.5, 5.0, num_basis))
        self.phases = nn.Parameter(torch.randn(num_basis) * 0.5)
        self.amplitudes = nn.Parameter(torch.ones(num_basis) * 0.1)
        
        # Time scaling (learnable)
        self.time_scale = nn.Parameter(torch.tensor(1.0))
        
        # Layer norm
        self.norm = nn.LayerNorm(out_features)
        
    def get_alphas(self, t):
        """
        Compute basis coefficients α_i(t) for given time t.
        Using Fourier features for smooth trajectories.
        """
        # t is in [0, 1] - scale to reasonable range
        t_scaled = t * self.time_scale
        
        # Fourier basis
        alphas = self.amplitudes * torch.sin(2 * np.pi * self.freqs * t_scaled + self.phases)
        
        return alphas
    
    def get_weight_at_time(self, t):
        """
        Compute W(t) = W0 + Σ α_i(t) U_i V_iᵀ
        """
        alphas = self.get_alphas(t)
        
        # Start with base weight
        W_t = self.W0.clone()
        
        # Add trajectory components
        for i in range(self.num_basis):
            # U_i V_iᵀ is the direction of movement
            direction = self.U[i] @ self.V[i].T  # (out_features, in_features)
            W_t = W_t + alphas[i] * direction
        
        return W_t
    
    def forward(self, x, t):
        """
        x: (batch, in_features)
        t: scalar or (batch,) tensor of times
        """
        batch_size = x.shape[0]
        
        # Handle t
        if isinstance(t, (float, int)):
            t_tensor = torch.full((batch_size,), t, device=x.device)
        else:
            t_tensor = t.to(x.device)
        
        # For each sample in batch, compute weight at its time
        # This is the key - each sample can be at a different point on the trajectory
        outputs = []
        
        for i in range(batch_size):
            t_i = t_tensor[i]
            W_t = self.get_weight_at_time(t_i)
            out_i = F.linear(x[i:i+1], W_t, self.b0)
            outputs.append(out_i)
        
        out = torch.cat(outputs, dim=0)
        return self.norm(out)
    
    def trajectory_distance(self, t1, t2):
        """Measure distance between two points on the weight trajectory."""
        W1 = self.get_weight_at_time(t1)
        W2 = self.get_weight_at_time(t2)
        return torch.norm(W1 - W2).item()


# ----------------------------------------------------------------------
# Continuous Temporal Network
# ----------------------------------------------------------------------
class ContinuousTemporalNet(nn.Module):
    """
    Network where every layer follows a continuous trajectory through weight space.
    """
    def __init__(self, input_dim=784, hidden_dim=256, num_classes=10, num_basis=5):
        super().__init__()
        
        self.input_dim = input_dim
        self.hidden_dim = hidden_dim
        self.num_classes = num_classes
        
        # Continuous temporal layers
        self.layer1 = ContinuousTemporalLayer(input_dim, hidden_dim, rank=8, num_basis=num_basis)
        self.layer2 = ContinuousTemporalLayer(hidden_dim, hidden_dim, rank=8, num_basis=num_basis)
        self.layer3 = ContinuousTemporalLayer(hidden_dim, hidden_dim, rank=8, num_basis=num_basis)
        
        # Output layer (shared across time)
        self.output = nn.Linear(hidden_dim, num_classes)
        
        # Dropout
        self.dropout = nn.Dropout(0.2)
        
        # For tracking trajectories
        self.trajectory_points = []
        
    def forward(self, x, t):
        """
        x: (batch, 1, 28, 28) or (batch, 784)
        t: scalar or (batch,) tensor of times
        """
        batch_size = x.shape[0]
        
        # Flatten if needed
        if len(x.shape) > 2:
            x = x.view(batch_size, -1)
        
        # Pass through temporal layers
        x = F.relu(self.layer1(x, t))
        x = self.dropout(x)
        x = F.relu(self.layer2(x, t))
        x = self.dropout(x)
        x = F.relu(self.layer3(x, t))
        
        return self.output(x)
    
    def get_trajectory(self, t_start=0, t_end=1, num_points=50):
        """Sample the weight trajectory at multiple times."""
        times = torch.linspace(t_start, t_end, num_points)
        
        # Get weights at each time for each layer
        trajectory = {
            'layer1': [],
            'layer2': [],
            'layer3': []
        }
        
        with torch.no_grad():
            for t in times:
                t = t.to(device)
                trajectory['layer1'].append(self.layer1.get_weight_at_time(t).cpu().numpy())
                trajectory['layer2'].append(self.layer2.get_weight_at_time(t).cpu().numpy())
                trajectory['layer3'].append(self.layer3.get_weight_at_time(t).cpu().numpy())
        
        return times.cpu().numpy(), trajectory
    
    def function_similarity(self, loader, t1, t2):
        """Measure how similar the network's function is at two times."""
        self.eval()
        preds1 = []
        preds2 = []
        
        with torch.no_grad():
            for data, target in loader:
                data = data.to(device)
                t1_tensor = torch.full((data.shape[0],), t1, device=device)
                t2_tensor = torch.full((data.shape[0],), t2, device=device)
                
                logits1 = self.forward(data, t1_tensor)
                logits2 = self.forward(data, t2_tensor)
                
                preds1.extend(torch.argmax(logits1, dim=1).cpu().numpy())
                preds2.extend(torch.argmax(logits2, dim=1).cpu().numpy())
        
        # Compute agreement rate
        agreement = np.mean(np.array(preds1) == np.array(preds2))
        return agreement


# ----------------------------------------------------------------------
# Training with Time as a Necessary Dimension
# ----------------------------------------------------------------------
def train_continuous_temporal(model, train_loader, test_loader, epochs=30):
    """
    Train where time is NECESSARY because different samples have different times.
    """
    optimizer = optim.Adam(model.parameters(), lr=0.001)
    scheduler = optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=epochs)
    
    print("\n" + "="*80)
    print("TRAINING CONTINUOUS TEMPORAL NETWORK")
    print("="*80)
    print(f"Model parameters: {sum(p.numel() for p in model.parameters()):,}")
    print(f"Each layer has {model.layer1.num_basis} basis functions")
    print("\nEpoch    Loss    TestAcc  TrajLength")
    print("-" * 50)
    
    trajectory_lengths = []
    
    for epoch in range(epochs):
        model.train()
        total_loss = 0
        num_batches = 0
        
        for data, target in train_loader:
            data, target = data.to(device), target.to(device)
            
            # CRITICAL: Each sample gets a DIFFERENT random time
            # This forces the network to use time - it can't ignore it
            t = torch.rand(data.shape[0], device=device)
            
            logits = model(data, t)
            loss = F.cross_entropy(logits, target)
            
            optimizer.zero_grad()
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            optimizer.step()
            
            total_loss += loss.item()
            num_batches += 1
        
        avg_loss = total_loss / num_batches
        scheduler.step()
        
        # Test
        if (epoch + 1) % 5 == 0:
            test_acc = test_continuous(model, test_loader)
            
            # Measure trajectory length
            with torch.no_grad():
                dist = model.layer1.trajectory_distance(0.0, 1.0)
                trajectory_lengths.append(dist)
            
            print(f"{epoch+1:4d}    {avg_loss:.4f}   {test_acc:.4f}   {dist:.4f}")
    
    return model, trajectory_lengths


def test_continuous(model, loader):
    """Test at multiple times."""
    model.eval()
    correct = 0
    total = 0
    
    with torch.no_grad():
        for data, target in loader:
            data, target = data.to(device), target.to(device)
            
            # Test at several fixed times
            for t in [0.0, 0.25, 0.5, 0.75, 1.0]:
                t_tensor = torch.full((data.shape[0],), t, device=device)
                logits = model(data, t_tensor)
                pred = torch.argmax(logits, dim=1)
                correct += (pred == target).sum().item()
                total += len(data)
    
    return correct / total


# ----------------------------------------------------------------------
# Analysis: Is Time Actually Being Used?
# ----------------------------------------------------------------------
def analyze_temporal_behavior(model, test_loader):
    """Check if time actually changes the network's behavior."""
    
    print("\n" + "="*80)
    print("ANALYZING TEMPORAL BEHAVIOR")
    print("="*80)
    
    # Test 1: Function similarity across times
    print("\n1. Function Similarity Across Time")
    times = [0.0, 0.25, 0.5, 0.75, 1.0]
    
    sim_matrix = np.zeros((len(times), len(times)))
    for i, t1 in enumerate(times):
        for j, t2 in enumerate(times):
            sim = model.function_similarity(test_loader, t1, t2)
            sim_matrix[i, j] = sim
    
    print("\nSimilarity Matrix (agreement rate):")
    print("t\\t", end="")
    for t in times:
        print(f"  {t:.2f}", end="")
    print()
    
    for i, t1 in enumerate(times):
        print(f"{t1:.2f} ", end="")
        for j, t2 in enumerate(times):
            print(f"  {sim_matrix[i, j]:.3f}", end="")
        print()
    
    off_diag = sim_matrix[~np.eye(len(times), dtype=bool)].mean()
    print(f"\nAverage off-diagonal similarity: {off_diag:.3f}")
    
    if off_diag < 0.9:
        print("✅✅✅ TIME MATTERS! Different times produce different functions!")
    else:
        print("❌ Still too similar - need stronger trajectory")
    
    # Test 2: Trajectory visualization
    print("\n2. Weight Trajectory")
    times, trajectory = model.get_trajectory(0, 1, 20)
    
    # Compute trajectory length for each layer
    for layer_name, weights in trajectory.items():
        # Convert to array and compute distances
        weights_array = np.array(weights)
        total_dist = 0
        for i in range(len(weights_array)-1):
            dist = np.linalg.norm(weights_array[i+1] - weights_array[i])
            total_dist += dist
        print(f"  {layer_name} trajectory length: {total_dist:.4f}")
    
    # Test 3: Prediction consistency within same time
    print("\n3. Prediction Consistency")
    
    model.eval()
    with torch.no_grad():
        data, target = next(iter(test_loader))
        data = data[:10].to(device)
        
        # Same time - predictions should be identical
        t_same = torch.full((10,), 0.5, device=device)
        logits1 = model(data, t_same)
        logits2 = model(data, t_same)
        pred1 = torch.argmax(logits1, dim=1)
        pred2 = torch.argmax(logits2, dim=1)
        same_time_agree = (pred1 == pred2).float().mean().item()
        
        # Different times - predictions may differ
        t_diff1 = torch.full((10,), 0.2, device=device)
        t_diff2 = torch.full((10,), 0.8, device=device)
        logits3 = model(data, t_diff1)
        logits4 = model(data, t_diff2)
        pred3 = torch.argmax(logits3, dim=1)
        pred4 = torch.argmax(logits4, dim=1)
        diff_time_agree = (pred3 == pred4).float().mean().item()
        
        print(f"  Same time agreement: {same_time_agree:.3f}")
        print(f"  Different time agreement: {diff_time_agree:.3f}")
        print(f"  Time effect: {same_time_agree - diff_time_agree:.3f}")
    
    return off_diag


# ----------------------------------------------------------------------
# Main Experiment
# ----------------------------------------------------------------------
def main():
    """Run the continuous temporal manifold experiment."""
    
    # Load MNIST
    transform = transforms.Compose([
        transforms.ToTensor(),
        transforms.Normalize((0.1307,), (0.3081,))
    ])
    
    train_dataset = datasets.MNIST('./data', train=True, download=True, transform=transform)
    test_dataset = datasets.MNIST('./data', train=False, transform=transform)
    
    train_loader = DataLoader(train_dataset, batch_size=64, shuffle=True)
    test_loader = DataLoader(test_dataset, batch_size=64)
    
    # Create model
    model = ContinuousTemporalNet(
        input_dim=784,
        hidden_dim=256,
        num_classes=10,
        num_basis=8  # More basis functions for richer trajectories
    ).to(device)
    
    # Train
    model, traj_lengths = train_continuous_temporal(model, train_loader, test_loader, epochs=30)
    
    # Analyze
    off_diag = analyze_temporal_behavior(model, test_loader)
    
    # Final verdict
    print("\n" + "="*80)
    print("FINAL VERDICT")
    print("="*80)
    
    if off_diag < 0.9:
        print("""
        ✅✅✅ SUCCESS! 
        
        The network now uses time as a necessary dimension:
        - Different times produce different functions
        - Weight trajectories are non-trivial
        - Time affects predictions
        
        This is the continuous weight trajectory idea working!
        
        Next steps:
        1. Try on FashionMNIST vs MNIST (different trajectories)
        2. Measure interpolation quality
        3. Test on regression tasks
        4. Analyze trajectory geometry
        """)
    else:
        print("""
        ❌ Still not working. The network is finding ways to ignore time.
        
        Possible fixes:
        1. Increase rank of trajectory components
        2. Add more basis functions
        3. Make time range larger (t in [0,10] instead of [0,1])
        4. Add temporal regularization loss
        """)
    
    # Save model
    torch.save(model.state_dict(), 'continuous_temporal_model.pt')
    print("\n✓ Model saved to continuous_temporal_model.pt")
    
    return model


if __name__ == "__main__":
    model = main()
